{
  "config": {
    "body": [
      "config = function()",
      "\trequire(\"${1:Name}\").setup()",
      "end"
    ],
    "prefix": "config"
  },
  "comment": {
    "body": "----------------------------------------$1----------------------------------------",
    "prefix": "comment"
  },
  "opts": {
    "body": "opts = {}",
    "prefix": "opts"
  },
  "return (new plugins)": {
    "body": [
      "return {",
      "\t{ \"$1\", opts = {$0} },",
      "}"
    ],
    "prefix": "return (new plugins)"
  },
  "keymap(normal)": {
    "body": "vim.keymap.set(\"${1:mode}\",\"${2:key}\",\"${3:cmd}\",{desc = \"$4\"})",
    "prefix": "keymap(normal)"
  }
}
